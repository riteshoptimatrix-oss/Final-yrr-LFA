# Production — Direct ngrok connection (no proxy needed)
# These MUST be set to your current ngrok HTTPS URL for production builds.
# Use the startup script (scripts/start-production.sh) to auto-detect and set these.
#
# NEXT_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.app/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://your-ngrok-url.ngrok-free.app
# If left empty, the app will fall back to /api/v1 via Netlify _redirects proxy.
# The _redirects file must contain a valid ngrok URL for this to work.
NEXT_PUBLIC_API_URL=https://egotistic-shack-thigh.ngrok-free.dev/api/v1
NEXT_PUBLIC_SOCKET_URL=https://egotistic-shack-thigh.ngrok-free.dev

# Geoapify Autocomplete API key (for area search)
NEXT_PUBLIC_GEOAPIFY_KEY=d93c1dbd204e4663b75e69c8230b754c
